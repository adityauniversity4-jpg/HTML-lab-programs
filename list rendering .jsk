import React from "react";

function ListRendering() {
  const students = ["Kavya", "Ramya", "Sree"];

  return (
    <div>
      <h1>Student List</h1>

      <ul>
        {students.map((name, index) => (
          <li key={index}>{name}</li>
        ))}
      </ul>

    </div>
  );
}

export default ListRendering;
